# Exclude everything first
*

# Include pre-built dist
!dist/
!dist/**

# Include essential runtime files
!src/
!src/**
!package.json
!yarn.lock
!tsconfig.json
!tsconfig.build.json
!nest-cli.json
!instrumentation.ts

# Include Prisma schema (for prisma generate)
!prisma/
!prisma/**

# Re-exclude test files
src/**/*.spec.ts
src/**/*.test.ts
